generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Guest {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  phone     String?
  status    String    @default("pending")
  title     String    @default("Bapak/Ibu")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  guestId   String
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  message   String
  confirm   String   @default("")
  createdAt DateTime @default(now())
}

model Template {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  type      String
  guestId   String?
  detail    String?
  createdAt DateTime @default(now())
}
