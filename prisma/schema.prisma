generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Guest {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  phone     String?
  status    String    @default("pending")
  title     String    @default("Bapak/Ibu") // Bapak, Ibu, Bapak/Ibu
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  guestId   String
  guest     Guest    @relation(fields: [guestId], references: [id])
  message   String
  confirm   String   @default("") // hadir, tidak hadir, ragu
  createdAt DateTime @default(now())
}

model Template {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  type      String   // sent_wa, opened, commented
  guestId   String?
  detail    String?
  createdAt DateTime @default(now())
}
